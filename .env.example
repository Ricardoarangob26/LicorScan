# Modo de ejecución: true para ver el navegador (desarrollo), false para producción
HEADLESS=false

# Delay entre requests en segundos (según tu DTD)
EXITO_DELAY=12
CARULLA_DELAY=12
D1_DELAY=8
OLIMPICA_DELAY=8
LAREBAJA_DELAY=8
FARMATODO_DELAY=10

# Max productos por categoría en modo dev (para no tardarse horas)
MAX_PRODUCTS_PER_CATEGORY=20
MAX_PAGES_PER_CATEGORY=35

# Mantener solo los últimos N archivos por tipo (jsonl/xhr) y tienda.
OUTPUT_KEEP_LAST=3

# Carpeta de output
OUTPUT_DIR=data/raw

# --- Automatización jobs/cache ---
# Frecuencia de ejecución por tienda para el scheduler automático.
JOB_INTERVAL_MINUTES=180
# TTL lógico del caché para consumidores de frontend/API.
CACHE_TTL_MINUTES=30
# Origen por defecto para job cache-only: raw_jsonl o db_json.
CACHE_SOURCE=raw_jsonl
# Pausa entre verificaciones del scheduler.
JOB_LOOP_SLEEP_SECONDS=45
